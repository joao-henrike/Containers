    def _run_install(self, command, log):
        """Execute installation command and log output"""
        log.write(f"Running: {' '.join(command)}\n")
        result = subprocess.run(command, capture_output=True, text=True)
        log.write(result.stdout)
        if result.stderr:
            log.write(f"STDERR: {result.stderr}\n")
        if result.returncode != 0:
            raise Exception(f"Command failed: {' '.join(command)}")
    
    def remove(self, module_name):
        """Remove an installed module"""
        installed_marker = self.installed_dir / module_name
        
        if not installed_marker.exists():
            print(f"❌ Module '{module_name}' is not installed")
            return 1
        
        # Confirmation
        confirm = input(f"Remove {module_name}? [y/N]: ").strip().lower()
        if confirm != 'y':
            print("❌ Removal cancelled")
            return 1
        
        # Remove
        installed_marker.unlink()
        
        # Audit log
        if self.audit:
            self.audit.log_event(
                event_type='module_remove',
                user=os.environ.get('USER', 'sherlock'),
                details={'module': module_name}
            )
        
        print(f"✅ {module_name} removed")
        return 0


