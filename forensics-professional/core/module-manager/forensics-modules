        epilog='Example: forensics-modules install cloud-forensics --only aws-tools,gcp-tools'
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # List command
    list_parser = subparsers.add_parser('list', help='List available modules')
    list_parser.add_argument('--category', help='Filter by category')
    
    # Info command
    info_parser = subparsers.add_parser('info', help='Show module information')
    info_parser.add_argument('module', help='Module name')
    
    # Install command
    install_parser = subparsers.add_parser('install', help='Install module')
    install_parser.add_argument('module', help='Module name')
    install_parser.add_argument('--only', help='Install only specific sub-modules (comma-separated)')
    install_parser.add_argument('--interactive', action='store_true', help='Interactive sub-module selection')
    
    # Remove command
    remove_parser = subparsers.add_parser('remove', help='Remove module')
    remove_parser.add_argument('module', help='Module name')
    
    # Status command
    subparsers.add_parser('status', help='Show installed modules')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    manager = ModuleManager()
    
    if args.command == 'list':
        manager.list_modules(category=args.category)
    elif args.command == 'info':
        return manager.info(args.module)
    elif args.command == 'install':
        return manager.install(args.module, only_submodules=args.only, interactive=args.interactive)
    elif args.command == 'remove':
        return manager.remove(args.module)
    elif args.command == 'status':
        manager.list_modules()
    
    return 0


if __name__ == '__main__':
    sys.exit(main())
