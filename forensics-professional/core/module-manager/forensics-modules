# ==============================================================================

class InstallRunner:
    def __init__(self, log_file: str):
        self.log_file = log_file

    def run(self, cmd, description: str = "", ignore_failure: bool = False) -> bool:
        cmd_str = " ".join(str(c) for c in cmd)
        _log_install(self.log_file, f"Running: {cmd_str}")

        try:
            result = subprocess.run(
                cmd,
                capture_output=True, text=True,
                timeout=600
            )
            if result.stdout:
                _log_install(self.log_file, f"STDOUT: {result.stdout[:500]}")
            if result.stderr:
                _log_install(self.log_file, f"STDERR: {result.stderr[:500]}")

            if result.returncode != 0 and not ignore_failure:
                _log_install(self.log_file,
                             f"FAILED (exit {result.returncode}): {cmd_str}")
                raise RuntimeError(f"Command failed: {cmd_str}")

            return result.returncode == 0
        except subprocess.TimeoutExpired:
            _log_install(self.log_file, f"TIMEOUT: {cmd_str}")
            if not ignore_failure:
                raise RuntimeError(f"Command timed out: {cmd_str}")
            return False
        except RuntimeError:
            raise
        except Exception as e:
            _log_install(self.log_file, f"ERROR: {e}")
            if not ignore_failure:
                raise RuntimeError(str(e))
            return False


