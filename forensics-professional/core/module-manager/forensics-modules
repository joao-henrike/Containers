    def list_modules(self, category=None):
        """List available modules"""
        modules = self.registry.get('modules', {})
        
        table_data = []
        for name, info in sorted(modules.items()):
            if category and info.get('category') != category:
                continue
            
            # Check if installed
            installed = '✅' if (self.installed_dir / name).exists() else '❌'
            
            table_data.append([
                name,
                info.get('category', 'N/A'),
                info.get('stable_version', 'N/A'),
                ', '.join(info.get('submodules', [])),
                installed
            ])
        
        headers = ['Module', 'Category', 'Version', 'Sub-modules', 'Installed']
        print(tabulate(table_data, headers=headers, tablefmt='grid'))
    
    def info(self, module_name):
