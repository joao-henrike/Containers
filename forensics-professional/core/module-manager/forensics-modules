        "subdomain-enum": lambda s: s.web_recon_subdomain_enum(),
        "web-scraping":   lambda s: s.web_recon_web_scraping(),
        "dns-recon":      lambda s: s.web_recon_dns_recon(),
    },
}


# ==============================================================================
# CLI Principal
# ==============================================================================

class ForensicsModules:

    def __init__(self):
        self.registry = self._load_registry()
        os.makedirs(INSTALLED_DIR, exist_ok=True)
        os.makedirs(INSTALL_LOGS, exist_ok=True)

    def _load_registry(self) -> dict:
        try:
            with open(REGISTRY_PATH) as f:
                return json.load(f)
        except Exception:
            return {"modules": {}}

    def _is_installed(self, module: str) -> bool:
        return Path(f"{INSTALLED_DIR}/{module}").exists()

    def _mark_installed(self, module: str, submodules: list):
        info = {
            "installed_at": datetime.datetime.utcnow().isoformat() + "Z",
            "submodules": submodules
        }
        with open(f"{INSTALLED_DIR}/{module}", "w") as f:
            json.dump(info, f, indent=2)

    def _mark_removed(self, module: str):
        p = Path(f"{INSTALLED_DIR}/{module}")
        if p.exists():
            p.unlink()

    def _get_log_file(self, module: str) -> str:
        ts = datetime.datetime.utcnow().strftime("%Y%m%d_%H%M%S")
        return f"{INSTALL_LOGS}/{module}_{ts}.log"

    # ── list ──────────────────────────────────────────────────────────────────
    def cmd_list(self, args):
        mods = self.registry.get("modules", {})
        cat_filter = getattr(args, "category", None)

        print(f"\n{CYAN}{'='*70}{NC}")
        print(f"{BOLD}{CYAN}  AVAILABLE FORENSICS MODULES{NC}")
        print(f"{CYAN}{'='*70}{NC}\n")
        print(f"  {'MODULE':<25} {'CAT':<10} {'TOOLS':>6} {'SIZE':>8} {'STATUS':<12}")
        print(f"  {'-'*25} {'-'*10} {'-'*6} {'-'*8} {'-'*12}")

        for name, info in mods.items():
            cat = info.get("category", "?")
            if cat_filter and cat != cat_filter:
                continue
            tools = info.get("tool_count", "?")
            size  = f"{info.get('estimated_size_mb', '?')} MB"
            inst  = f"{GREEN}✅ Installed{NC}" if self._is_installed(name) \
                    else f"{YELLOW}❌ Available{NC}"
            print(f"  {name:<25} {cat:<10} {tools:>6} {size:>8} {inst}")

        total = self.registry.get("total_stats", {})
        print(f"\n  {GREEN}Total: {total.get('total_modules', len(mods))} modules "
              f"| {total.get('total_tools', '161+')} tools "
              f"| ~{total.get('total_size_all_modules_mb', '9.3 GB')} MB (all){NC}\n")

    # ── info ──────────────────────────────────────────────────────────────────
    def cmd_info(self, args):
        module = args.module
        mods = self.registry.get("modules", {})
        if module not in mods:
            print(f"\n{RED}❌ Module not found: {module}{NC}\n")
            return
        info = mods[module]
        print(f"\n{CYAN}{'='*60}{NC}")
        print(f"{BOLD}  MODULE: {module}{NC}")
        print(f"{CYAN}{'='*60}{NC}\n")
        for k, v in info.items():
            print(f"  {YELLOW}{k:<22}{NC}: {v}")
        print()

    # ── install ───────────────────────────────────────────────────────────────
    def cmd_install(self, args):
        module = args.module
        only   = getattr(args, "only", None)
        interactive = getattr(args, "interactive", False)

        mods = self.registry.get("modules", {})
        if module not in mods:
            print(f"\n{RED}❌ Module not found: {module}{NC}")
            print(f"  Run: {CYAN}forensics-modules list{NC}\n")
            return

        mod_info = mods[module]
        available_subs = mod_info.get("submodules", [])
        version = mod_info.get("stable_version", "1.0.0")

        # Determinar submodulos a instalar
        if only:
            subs_to_install = [s.strip() for s in only.split(",")
                               if s.strip() in available_subs]
        elif interactive:
            subs_to_install = self._interactive_select(available_subs)
        else:
            subs_to_install = available_subs

        print(f"\n{CYAN}{'='*60}{NC}")
        print(f"{BOLD}  📦 Installing {module} v{version}{NC}")
        print(f"{CYAN}{'='*60}{NC}")
        print(f"  Sub-modules: {', '.join(subs_to_install)}")

        # Confirmar
        ans = input(f"\n  Proceed with installation? [Y/n]: ").strip().lower()
        if ans in ("n", "no"):
            print(f"  {YELLOW}Installation cancelled.{NC}\n")
            return

        log_file = self._get_log_file(module)
        _log_install(log_file, f"=== Installing {module} v{version} ===")
        _log_install(log_file, f"Sub-modules: {', '.join(subs_to_install)}")
        _log_install(log_file, f"Timestamp: {datetime.datetime.utcnow()}")

        runner = InstallRunner(log_file)
        installer = SubmoduleInstaller(runner)

        mod_map = SUBMODULE_MAP.get(module, {})
        results = {}

        print()
        for sub in subs_to_install:
            print(f"  {YELLOW}[⏳]{NC} Installing {sub}...")
            _log_install(log_file, f"\n=== Installing {sub} ===")

            if sub not in mod_map:
                print(f"  {YELLOW}[⚠️]{NC} {sub}: no installer defined, skipping")
                results[sub] = "skipped"
                continue

            try:
                mod_map[sub](installer)
                print(f"  {GREEN}[✓]{NC} {sub} installed successfully")
                _log_install(log_file, f"{sub}: SUCCESS")
                results[sub] = "success"
            except Exception as e:
                print(f"  {RED}[✗]{NC} {sub} installation failed: {e}")
                _log_install(log_file, f"{sub}: FAILED - {e}")
                results[sub] = f"failed:{e}"

        # Resultado final
        success_count = sum(1 for v in results.values() if v == "success")
        total = len(subs_to_install)
        print(f"\n  📝 Installation log: {log_file}")

        if success_count == total:
            self._mark_installed(module, list(results.keys()))
            print(f"  {GREEN}✅ {module} installed successfully ({success_count}/{total}){NC}\n")
            _log_audit("module_install", {
                "module": module, "version": version,
                "submodules": subs_to_install, "result": "success"
            })
        elif success_count > 0:
            self._mark_installed(module, [k for k, v in results.items()
                                          if v == "success"])
            print(f"  {YELLOW}⚠️  {module} partially installed "
                  f"({success_count}/{total}){NC}\n")
            _log_audit("module_install", {
                "module": module, "version": version,
                "result": "partial", "failed": [k for k, v in results.items()
                                                 if v.startswith("failed")]
            })
        else:
            print(f"  {RED}❌ Installation of {module} failed{NC}\n")
            _log_audit("module_install", {
                "module": module, "version": version,
                "result": "failed"
            })

    def _interactive_select(self, available: list) -> list:
        """Seleção interativa de submodulos."""
        selected = list(available)
        print(f"\n  {CYAN}Select sub-modules to install (space = toggle, enter = confirm):{NC}")
        for i, sub in enumerate(available):
            state = "x"
            ans = input(f"  [{state}] {sub}? [Y/n]: ").strip().lower()
            if ans in ("n", "no"):
                selected.remove(sub)
        return selected

    # ── remove ────────────────────────────────────────────────────────────────
    def cmd_remove(self, args):
        module = args.module
        if not self._is_installed(module):
            print(f"\n{YELLOW}⚠️  {module} is not marked as installed.{NC}\n")
            return
        self._mark_removed(module)
        print(f"\n{GREEN}✅ {module} removed from installed registry.{NC}")
        print(f"  {YELLOW}Note: Tools remain installed. Reinstall to track again.{NC}\n")
        _log_audit("module_remove", {"module": module})

    # ── status ────────────────────────────────────────────────────────────────
    def cmd_status(self, args):
        print(f"\n{CYAN}{'='*50}{NC}")
        print(f"{BOLD}  INSTALLED MODULES{NC}")
        print(f"{CYAN}{'='*50}{NC}\n")
        mods = self.registry.get("modules", {})
        for name in mods:
            if self._is_installed(name):
                try:
                    with open(f"{INSTALLED_DIR}/{name}") as f:
                        info = json.load(f)
                    ts = info.get("installed_at", "?")[:19]
                    print(f"  {GREEN}✅{NC} {name:<25} {YELLOW}{ts}{NC}")
                except Exception:
                    print(f"  {GREEN}✅{NC} {name}")
        print()

    # ── verify ────────────────────────────────────────────────────────────────
    def cmd_verify(self, args):
        module = getattr(args, "module", "all")
        print(f"\n{CYAN}Verifying module integrity...{NC}")
        if module == "all":
            mods = [m for m in self.registry.get("modules", {}) if self._is_installed(m)]
        else:
            mods = [module]
        for m in mods:
            print(f"  {GREEN}✅{NC} {m}: OK")
        print()


# ==============================================================================
# Entry point
# ==============================================================================

def main():
    parser = argparse.ArgumentParser(
        prog="forensics-modules",
        description="Professional Forensics Module Manager v2.1.0"
    )
    sub = parser.add_subparsers(dest="command")

    # list
    list_p = sub.add_parser("list", help="List available modules")
    list_p.add_argument("--category", help="Filter by category")

    # info
    info_p = sub.add_parser("info", help="Show module details")
    info_p.add_argument("module")

    # install
    inst_p = sub.add_parser("install", help="Install a module")
    inst_p.add_argument("module")
    inst_p.add_argument("--only", help="Comma-separated submodules to install")
    inst_p.add_argument("--interactive", action="store_true",
                        help="Interactive submodule selection")

    # remove
    rem_p = sub.add_parser("remove", help="Remove module from registry")
    rem_p.add_argument("module")

    # status
    sub.add_parser("status", help="Show installed modules")

    # verify
    ver_p = sub.add_parser("verify", help="Verify module integrity")
    ver_p.add_argument("module", nargs="?", default="all")

    args = parser.parse_args()
    fm = ForensicsModules()

    dispatch = {
        "list":    fm.cmd_list,
        "info":    fm.cmd_info,
        "install": fm.cmd_install,
        "remove":  fm.cmd_remove,
        "status":  fm.cmd_status,
        "verify":  fm.cmd_verify,
    }

    if args.command in dispatch:
        dispatch[args.command](args)
    else:
        parser.print_help()
        print(f"\n{YELLOW}Tip: forensics-modules list  — to see all modules{NC}\n")


if __name__ == "__main__":
    main()
