            print(f"❌ Module '{module_name}' not found in registry")
            return 1
        
        info = self.registry['modules'][module_name]
        
        print(f"\n📦 Module: {module_name}")
        print("=" * 60)
        print(f"Description:    {info.get('description', 'N/A')}")
        print(f"Category:       {info.get('category', 'N/A')}")
        print(f"Stable Version: {info.get('stable_version', 'N/A')}")
        print(f"Sub-modules:    {', '.join(info.get('submodules', []))}")
        print()
        
        # Check installation status
        installed_marker = self.installed_dir / module_name
        if installed_marker.exists():
            with open(installed_marker, 'r') as f:
                install_info = json.load(f)
            
            print("✅ Status: INSTALLED")
            print(f"   Installed:     {install_info.get('timestamp', 'N/A')}")
            print(f"   Version:       {install_info.get('version', 'N/A')}")
            print(f"   Sub-modules:   {', '.join(install_info.get('submodules', []))}")
        else:
            print("❌ Status: NOT INSTALLED")
        
        return 0
    
    def install(self, module_name, only_submodules=None, interactive=False):
        """Install a module or specific sub-modules"""
        if module_name not in self.registry['modules']:
            print(f"❌ Module '{module_name}' not found")
            return 1
        
        module_info = self.registry['modules'][module_name]
        available_submodules = module_info.get('submodules', [])
        
        # Determine which sub-modules to install
        if only_submodules:
            # Specific sub-modules requested
            submodules_to_install = only_submodules.split(',')
            # Validate
            invalid = [s for s in submodules_to_install if s not in available_submodules]
            if invalid:
                print(f"❌ Invalid sub-modules: {', '.join(invalid)}")
                print(f"   Available: {', '.join(available_submodules)}")
                return 1
        elif interactive:
            # Interactive selection
            submodules_to_install = self._interactive_submodule_selection(available_submodules)
            if not submodules_to_install:
                print("❌ No sub-modules selected")
                return 1
        else:
            # Install all
            submodules_to_install = available_submodules
        
        print(f"\n📦 Installing {module_name} v{module_info['stable_version']}")
        print(f"   Sub-modules: {', '.join(submodules_to_install)}")
        print()
        
        # Confirmation
        confirm = input("Proceed with installation? [Y/n]: ").strip().lower()
        if confirm and confirm != 'y':
            print("❌ Installation cancelled")
            return 1
        
        # Check for conflicts
        conflicts = self._check_conflicts(module_name, submodules_to_install)
        if conflicts:
            if not self._handle_conflicts(conflicts):
                print("❌ Installation cancelled due to conflicts")
                return 1
        
        # Perform installation
        success = self._install_module(module_name, submodules_to_install, module_info)
        
        if success:
            # Mark as installed
            install_record = {
                'module': module_name,
                'version': module_info['stable_version'],
                'submodules': submodules_to_install,
                'timestamp': subprocess.check_output(['date', '-u', '+%Y-%m-%dT%H:%M:%SZ']).decode().strip()
            }
            
            with open(self.installed_dir / module_name, 'w') as f:
                json.dump(install_record, f, indent=2)
            
            # Audit log
            if self.audit:
                self.audit.log_event(
                    event_type='module_install',
                    user=os.environ.get('USER', 'sherlock'),
                    details={
                        'module': module_name,
                        'version': module_info['stable_version'],
                        'submodules': submodules_to_install
                    }
                )
            
            print(f"\n✅ {module_name} installed successfully!")
            return 0
        else:
            print(f"\n❌ Installation of {module_name} failed")
            return 1
    
    def _interactive_submodule_selection(self, submodules):
        """Interactive sub-module selection"""
        print("Select sub-modules to install:")
        selected = []
        
        for i, submodule in enumerate(submodules, 1):
            response = input(f"  [{i}] {submodule} [Y/n]: ").strip().lower()
            if not response or response == 'y':
                selected.append(submodule)
        
        return selected
    
