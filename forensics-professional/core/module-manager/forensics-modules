def _pip(*args):
    """Retorna comando pip3 correto (com --break-system-packages se disponível)."""
    base = ["pip3", "install"]
    # Testar suporte ao flag
    test = subprocess.run(["pip3", "install", "--help"],
                          capture_output=True, text=True, timeout=5)
    if "--break-system-packages" in test.stdout:
        base.append("--break-system-packages")
    return base + list(args)


def _apt(*pkgs):
    """Retorna comando apt-get install."""
    return ["sudo", "DEBIAN_FRONTEND=noninteractive",
            "apt-get", "install", "-y"] + list(pkgs)


def _sudo_apt_update():
    return ["sudo", "apt-get", "update"]


def _log_audit(event: str, details: dict):
    """Registra evento no audit trail criptográfico."""
    try:
        from audit_logger import log_event
        log_event(event, details)
    except Exception:
        pass  # Audit não pode quebrar o fluxo principal


def _log_install(log_file: str, message: str):
    """Escreve no log de instalação do módulo."""
    ts = datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")
    try:
        with open(log_file, "a") as f:
            f.write(f"[{ts}] {message}\n")
    except Exception:
        pass


