#!/usr/bin/env python3
"""
FORENSICS AUDIT CLI
Command-line interface for audit log management and verification
"""

import sys
import json
import argparse
from pathlib import Path
from datetime import datetime
from tabulate import tabulate

# Import audit logger
sys.path.insert(0, str(Path(__file__).parent))
from audit_logger import ForensicsAuditLogger


class ForensicsAuditCLI:
    """CLI for audit system operations"""
    
    def __init__(self):
        self.logger = ForensicsAuditLogger()
    
    def verify(self):
        """Verify integrity of audit log"""
        print("🔍 Verifying audit log integrity...")
        print("=" * 60)
        
        valid, result = self.logger.verify_integrity()
        
        if valid:
            print(f"✅ VALID: {result}")
            return 0
        else:
            print("❌ INVALID: Integrity check failed!")
            if isinstance(result, list):
                for error in result:
                    print(f"  • {error}")
            return 1
    
    def show(self, limit=20, event_type=None, user=None):
        """Show recent audit log entries"""
        if not self.logger.log_file.exists():
            print("No audit log found")
            return
        
        entries = []
        with open(self.logger.log_file, 'r') as f:
            for line in f:
                try:
                    entry = json.loads(line.strip())
                    
                    # Filter by event type
                    if event_type and entry['event_type'] != event_type:
                        continue
                    
                    # Filter by user
                    if user and entry['user'] != user:
                        continue
                    
                    entries.append(entry)
                except:
                    continue
        
        # Get last N entries
        recent = entries[-limit:] if len(entries) > limit else entries
        
        # Format for display
        table_data = []
        for entry in recent:
            table_data.append([
                entry['seq'],
                entry['timestamp'][:19],  # Truncate microseconds
                entry['user'],
                entry['event_type'],
                str(entry.get('details', {}))[:50]  # Truncate details
            ])
        
        headers = ['Seq', 'Timestamp (UTC)', 'User', 'Event', 'Details']
        print(tabulate(table_data, headers=headers, tablefmt='grid'))
        print(f"\nTotal entries: {len(entries)} | Showing: {len(recent)}")
    
    def export(self, output_file, format='json'):
        """Export audit log"""
        if not self.logger.log_file.exists():
            print("No audit log found")
            return 1
        
        entries = []
        with open(self.logger.log_file, 'r') as f:
            for line in f:
                try:
                    entries.append(json.loads(line.strip()))
                except:
                    continue
        
        output_path = Path(output_file)
        
        if format == 'json':
            with open(output_path, 'w') as f:
                json.dump(entries, f, indent=2)
        elif format == 'csv':
            import csv
            with open(output_path, 'w', newline='') as f:
                if entries:
                    writer = csv.DictWriter(f, fieldnames=entries[0].keys())
                    writer.writeheader()
                    writer.writerows(entries)
        
        print(f"✅ Exported {len(entries)} entries to {output_path}")
        return 0
    
    def stats(self):
        """Show audit log statistics"""
        if not self.logger.log_file.exists():
            print("No audit log found")
            return
        
        entries = []
        with open(self.logger.log_file, 'r') as f:
            for line in f:
                try:
                    entries.append(json.loads(line.strip()))
                except:
                    continue
        
        if not entries:
            print("No entries in audit log")
            return
        
        # Calculate statistics
        event_types = {}
        users = {}
        
        for entry in entries:
            event_type = entry.get('event_type', 'unknown')
            user = entry.get('user', 'unknown')
            
            event_types[event_type] = event_types.get(event_type, 0) + 1
            users[user] = users.get(user, 0) + 1
        
        print("📊 Audit Log Statistics")
        print("=" * 60)
        print(f"Total Entries: {len(entries)}")
        print(f"First Entry:   {entries[0]['timestamp']}")
        print(f"Last Entry:    {entries[-1]['timestamp']}")
        print()
        
        print("Event Types:")
        for event_type, count in sorted(event_types.items(), key=lambda x: x[1], reverse=True):
            print(f"  • {event_type}: {count}")
        print()
        
        print("Users:")
        for user, count in sorted(users.items(), key=lambda x: x[1], reverse=True):
            print(f"  • {user}: {count}")


def main():
    parser = argparse.ArgumentParser(
        description='Forensics Audit System CLI',
        epilog='Example: forensics-audit verify'
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # Verify command
    subparsers.add_parser('verify', help='Verify audit log integrity')
    
    # Show command
    show_parser = subparsers.add_parser('show', help='Show audit log entries')
    show_parser.add_argument('--limit', type=int, default=20, help='Number of entries to show')
    show_parser.add_argument('--event-type', help='Filter by event type')
    show_parser.add_argument('--user', help='Filter by user')
    
    # Export command
    export_parser = subparsers.add_parser('export', help='Export audit log')
    export_parser.add_argument('--output', required=True, help='Output file')
    export_parser.add_argument('--format', choices=['json', 'csv'], default='json')
    
    # Stats command
    subparsers.add_parser('stats', help='Show audit log statistics')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return 1
    
    cli = ForensicsAuditCLI()
    
    if args.command == 'verify':
        return cli.verify()
    elif args.command == 'show':
        cli.show(limit=args.limit, event_type=args.event_type, user=args.user)
    elif args.command == 'export':
        return cli.export(args.output, args.format)
    elif args.command == 'stats':
        cli.stats()
    
    return 0


if __name__ == '__main__':
    sys.exit(main())
